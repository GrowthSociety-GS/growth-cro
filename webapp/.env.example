# GrowthCRO V28 — Required environment variables for local dev + Vercel deploy.
# Copy to webapp/apps/<app>/.env.local for each app. Never commit .env.local.

# Supabase project (EU region, e.g. eu-west-3 / fra1)
# NEXT_PUBLIC_SUPABASE_URL is used by:
#   - the Supabase JS client (auth + Postgres queries)
#   - SP-11 screenshots (the `/api/screenshots/...` route 302-redirects to
#     `${url}/storage/v1/object/public/screenshots/<client>/<page>/<file>`
#     when this var is set; otherwise it falls back to filesystem reads
#     from `data/captures/...` — handy for local dev without Storage uploads).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-SERVICE-KEY

# Backend API — FastAPI exposed via Railway/Fly.io (Option B) OR Vercel edge functions (Option A)
NEXT_PUBLIC_API_BASE_URL=https://growthcro-api.fly.dev

# Microfrontends (Vercel)
MICROFRONTENDS_HOST_AUDIT=growthcro-audit.vercel.app
MICROFRONTENDS_HOST_RECO=growthcro-reco.vercel.app
MICROFRONTENDS_HOST_GSG=growthcro-gsg.vercel.app
MICROFRONTENDS_HOST_REALITY=growthcro-reality.vercel.app
MICROFRONTENDS_HOST_LEARNING=growthcro-learning.vercel.app

# Optional: app name visible in nav
NEXT_PUBLIC_APP_NAME=GrowthCRO V28
