{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "shell": {
      "production": {
        "host": "growthcro-shell.vercel.app",
        "fallback": "growthcro-shell.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-shell.vercel.app",
        "local": 3000
      }
    },
    "audit-app": {
      "production": {
        "host": "growthcro-audit.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-audit.vercel.app",
        "local": 3001
      },
      "routing": [
        {
          "group": "audit",
          "paths": ["/audit/:client*"]
        }
      ]
    },
    "reco-app": {
      "production": {
        "host": "growthcro-reco.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-reco.vercel.app",
        "local": 3002
      },
      "routing": [
        {
          "group": "reco",
          "paths": ["/reco/:client*"]
        }
      ]
    },
    "gsg-studio": {
      "production": {
        "host": "growthcro-gsg.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-gsg.vercel.app",
        "local": 3003
      },
      "routing": [
        {
          "group": "gsg",
          "paths": ["/gsg/:path*"]
        }
      ]
    },
    "reality-monitor": {
      "production": {
        "host": "growthcro-reality.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-reality.vercel.app",
        "local": 3004
      },
      "routing": [
        {
          "group": "reality",
          "paths": ["/reality/:path*"]
        }
      ]
    },
    "learning-lab": {
      "production": {
        "host": "growthcro-learning.vercel.app"
      },
      "development": {
        "fallback": "https://growthcro-learning.vercel.app",
        "local": 3005
      },
      "routing": [
        {
          "group": "learning",
          "paths": ["/learning/:path*"]
        }
      ]
    }
  }
}
