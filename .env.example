# GrowthCRO — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# NE JAMAIS committer .env (cf .gitignore)

# ══════════════════════════════════════════════════════
# Clé API Anthropic — OBLIGATOIRE pour scoring + recos
# ══════════════════════════════════════════════════════
# Utilisée par :
#   - skills/site-capture/scripts/semantic_scorer.py (Haiku 4.5)
#   - skills/site-capture/scripts/reco_enricher_v13_api.py (Sonnet 4.5)
# Obtenir : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════
# Apify token — OPTIONNEL (legacy Bright Data recaptures)
# ══════════════════════════════════════════════════════
# Utilisé par scripts legacy archivés (run_capture.py etc.)
# Plus requis en PROD depuis passage 100% Playwright.
# Laisse vide si tu ne recaptures pas via Apify.
APIFY_TOKEN=

# ══════════════════════════════════════════════════════
# Chemins locaux (facultatifs)
# ══════════════════════════════════════════════════════
# Si tu lances la pipeline depuis un autre dossier
GROWTHCRO_ROOT=


# ══════════════════════════════════════════════════════════════════════════
# V26.C — REALITY LAYER (data réelle business)
# ══════════════════════════════════════════════════════════════════════════
# Mode multi-tenant : credentials per-client > globaux
# Ex: pour activer Kaiju, copie chaque ligne et remplace _KAIJU par _<CLIENT>
# où <CLIENT> = slug en MAJUSCULES (kaiju → KAIJU, la-marque-en-moins → LA_MARQUE_EN_MOINS)
#
# Pour activer la fleet : ajoute autant de blocs <CLIENT> que de clients connectés.
# Le système skip auto les clients sans credentials.

# ─── Catchr (GA4 wrapper) ─────────────────────────────────
# Utilisé par : skills/site-capture/scripts/reality_layer/catchr.py
# Output : sessions, conversion_rate, primary_source_medium, device_split
CATCHR_API_KEY_KAIJU=
CATCHR_PROPERTY_ID_KAIJU=

# ─── Meta Marketing API (v18+) ────────────────────────────
# Utilisé par : reality_layer/meta_ads.py
# Output : ad_spend, roas, cpa, ctr, purchases par landing page
# Obtenir : https://developers.facebook.com/apps/ → Marketing API
META_ACCESS_TOKEN_KAIJU=EAAxxxxxxxxx
META_AD_ACCOUNT_ID_KAIJU=act_1234567890

# ─── Google Ads API (v15+) ────────────────────────────────
# Utilisé par : reality_layer/google_ads.py (requires google-ads SDK)
# Output : ad_spend, conversions, conversion_value, roas par landing
# Obtenir : https://developers.google.com/google-ads/api/docs/oauth/cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN_KAIJU=
GOOGLE_ADS_CLIENT_ID_KAIJU=
GOOGLE_ADS_CLIENT_SECRET_KAIJU=
GOOGLE_ADS_REFRESH_TOKEN_KAIJU=
GOOGLE_ADS_CUSTOMER_ID_KAIJU=1234567890

# ─── Shopify Admin GraphQL API (2024-10) ──────────────────
# Utilisé par : reality_layer/shopify.py
# Output : orders, revenue attribué par landing via customerJourneySummary
# Obtenir : Shopify Admin → Apps → Develop apps → Configure Admin API access
SHOPIFY_STORE_DOMAIN_KAIJU=kaiju.myshopify.com
SHOPIFY_ADMIN_API_TOKEN_KAIJU=shpat_xxxxxxxxxxxxxxxxxxxx

# ─── Microsoft Clarity Data Export ────────────────────────
# Utilisé par : reality_layer/clarity.py
# Output : rage_clicks, dead_clicks, scroll_depth, javascript_errors
# Limit : free tier last 3 days only
# Obtenir : https://clarity.microsoft.com → Settings → Data Export
CLARITY_API_TOKEN_KAIJU=
CLARITY_PROJECT_ID_KAIJU=


# ══════════════════════════════════════════════════════════════════════════
# V31+ — GEO READINESS MONITOR multi-engine
# ══════════════════════════════════════════════════════════════════════════
# Mode global (pas per-client — utilisé pour query LLMs avec brand_name du client)
# Smart sampling : cache 30j, monthly snapshots, 5-10 queries × 3 engines

# ─── OpenAI API (ChatGPT) ─────────────────────────────────
# Utilisé par : geo_readiness_monitor.py engine OpenAIEngine
# Modèle utilisé : gpt-4o-mini (cheap + capable)
# Obtenir : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Perplexity API ───────────────────────────────────────
# Utilisé par : geo_readiness_monitor.py engine PerplexityEngine
# Modèle utilisé : llama-3.1-sonar-small-128k-online (web search natif)
# Obtenir : https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx

# Note : Anthropic est déjà couvert par ANTHROPIC_API_KEY ci-dessus

