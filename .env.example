# GrowthCRO — environment variables
# Auto-generated from growthcro/config.py::_KNOWN_VARS
# Copy to `.env` and fill in your secrets. .env is gitignored.

# ── Required ─────────────────────────────────────────
# Claude API (Haiku scorer + Sonnet enricher). Required.
ANTHROPIC_API_KEY=

# ── Optional ─────────────────────────────────────────
# Apify cloud capture. Required only when running the cloud capture path.
APIFY_TOKEN=

# Optional — used by some multi-judge judges.
OPENAI_API_KEY=

# Optional — GEO module.
PERPLEXITY_API_KEY=

# Optional — Chrome UX Report (web vitals).
GROWTHCRO_CRUX_KEY=

# Optional — PageSpeed Insights (web vitals).
GROWTHCRO_PSI_KEY=

# 'crux' | 'psi' | 'none'. Default 'none'.
GROWTHCRO_WEB_VITALS_PROVIDER=none

# Optional — remote browser websocket (Apify/Browserless).
BROWSER_WS_ENDPOINT=

# Optional — BrightData browser proxy WSS.
BRIGHTDATA_WSS=

# Optional — BrightData auth token.
BRIGHTDATA_AUTH=

# '1' to run ghost_capture in headed mode for debugging.
GHOST_HEADED=0

# '1' to enable aggressive CMP (cookie banner) handling.
AGGRESSIVE_CMP=0

# FastAPI server port.
PORT=8000

# Observability log level (DEBUG|INFO|WARNING|ERROR). Default INFO. See growthcro/observability/logger.py.
GROWTHCRO_LOG_LEVEL=INFO

# Reality Layer — Catchr API key (GA4 wrapper used internally). Per-client: CATCHR_API_KEY_<SLUG>.
CATCHR_API_KEY=

# Reality Layer — Catchr property ID. Per-client: CATCHR_PROPERTY_ID_<SLUG>.
CATCHR_PROPERTY_ID=

# Reality Layer — Path to GA4 service account JSON. Per-client: GA4_SERVICE_ACCOUNT_JSON_<SLUG>.
GA4_SERVICE_ACCOUNT_JSON=

# Reality Layer — GA4 numeric property ID. Per-client: GA4_PROPERTY_ID_<SLUG>.
GA4_PROPERTY_ID=

# Reality Layer — Meta Marketing API access token. Per-client: META_ACCESS_TOKEN_<SLUG>.
META_ACCESS_TOKEN=

# Reality Layer — Meta ad account ID (act_…). Per-client: META_AD_ACCOUNT_ID_<SLUG>.
META_AD_ACCOUNT_ID=

# Reality Layer — Google Ads developer token. Per-client: GOOGLE_ADS_DEVELOPER_TOKEN_<SLUG> (rare; usually global).
GOOGLE_ADS_DEVELOPER_TOKEN=

# Reality Layer — Google Ads OAuth client ID. Per-client: GOOGLE_ADS_CLIENT_ID_<SLUG>.
GOOGLE_ADS_CLIENT_ID=

# Reality Layer — Google Ads OAuth client secret. Per-client: GOOGLE_ADS_CLIENT_SECRET_<SLUG>.
GOOGLE_ADS_CLIENT_SECRET=

# Reality Layer — Google Ads OAuth refresh token. Per-client: GOOGLE_ADS_REFRESH_TOKEN_<SLUG>.
GOOGLE_ADS_REFRESH_TOKEN=

# Reality Layer — Google Ads customer ID (10-digit, no dashes). Per-client: GOOGLE_ADS_CUSTOMER_ID_<SLUG>.
GOOGLE_ADS_CUSTOMER_ID=

# Reality Layer — Shopify store domain (e.g. shop.myshopify.com). Per-client: SHOPIFY_STORE_DOMAIN_<SLUG>.
SHOPIFY_STORE_DOMAIN=

# Reality Layer — Shopify Admin API access token. Per-client: SHOPIFY_ADMIN_API_TOKEN_<SLUG>.
SHOPIFY_ADMIN_API_TOKEN=

# Reality Layer — Microsoft Clarity Data Export token. Per-client: CLARITY_API_TOKEN_<SLUG>.
CLARITY_API_TOKEN=

# Reality Layer — Microsoft Clarity project ID. Per-client: CLARITY_PROJECT_ID_<SLUG>.
CLARITY_PROJECT_ID=
