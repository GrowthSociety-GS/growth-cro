{
  "$schema": "https://docs.claude.com/schemas/claude-code-settings.json",
  "description": "GrowthCRO — project-level Claude Code settings. Mis à jour 2026-04-27 — FULL AUTONOMY MODE (Mathis demande explicitement zéro prompt permission). skipDangerousModePermissionPrompt + defaultMode bypassPermissions.",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "Bash(python3 *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(wc*)",
      "Bash(du*)",
      "Bash(stat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(sort*)",
      "Bash(xargs*)",
      "Bash(echo*)",
      "Bash(mkdir*)",
      "Bash(touch*)",
      "Bash(test*)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(time *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(source *)",
      "Bash(export *)",
      "Bash(tee *)",
      "Bash(jq *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git reset*)",
      "Bash(git rm*)",
      "Bash(git init*)",
      "Bash(git -c *)",
      "Bash(git restore*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git tag*)",
      "Bash(git mv*)",
      "Bash(git clean*)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(playwright install*)",
      "Bash(brew *)",
      "Bash(brew install*)",
      "Bash(tesseract *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(./skills/*)",
      "Bash(./scripts/*)",
      "Bash(python3 skills/site-capture/scripts/*)",
      "Bash(python3 SCHEMA/*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)"
    ]
  },
  "env": {
    "GROWTHCRO_VERSION": "20.capture",
    "GROWTHCRO_PIPELINE_STAGE": "V20-capture-vision-pivot"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "paths": ["playbook/bloc_*_v3.json"],
        "command": "echo '[HOOK] Edit doctrine playbook — vérifie le schéma avant commit: python3 -c \"import json,sys; json.load(open(sys.argv[1]))\" \"${file}\"'"
      }
    ]
  }
}
